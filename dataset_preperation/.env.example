# Tigris (S3-compatible object storage) configuration for download.py
#
# Copy this file to `.env` in the same directory you run `download.py` from and fill
# in your values. `download.py` calls load_dotenv() at startup, so variables here are
# loaded into the environment automatically. Real shell environment variables always take
# precedence over this file.
#
# Get your access key from: https://console.storage.dev/createaccesskey

# Required: your Tigris access key id and secret access key.
AWS_ACCESS_KEY_ID=tid_your_access_key
AWS_SECRET_ACCESS_KEY=tsec_your_secret_key

# Tigris S3 endpoint. Leave as-is unless you need a different endpoint.
AWS_ENDPOINT_URL=https://t3.storage.dev

# Storage region. "auto" lets Tigris pick the closest region.
AWS_REGION=auto

# Bucket to upload completed subsets to. Defaults to "genau-dataset".
# Set this bucket's default tier to Archive (GLACIER) for cheap storage; the pipeline only
# lists and uploads data objects, never reads them, so archiving is safe.
TIGRIS_BUCKET=genau-dataset

# Bucket for the per-subset sha256sum.txt manifests. Defaults to "genau-dataset-manifests".
# KEEP THIS BUCKET IN THE STANDARD TIER so manifests are instantly readable for skip/verify.
TIGRIS_MANIFEST_BUCKET=genau-dataset-manifests

# --- Aliases (optional) -------------------------------------------------
# If you prefer TIGRIS_* names, these fill in only when the matching AWS_* variable
# above is NOT set:
#   TIGRIS_ACCESS_KEY_ID
#   TIGRIS_SECRET_ACCESS_KEY
#   TIGRIS_ENDPOINT_URL
#   TIGRIS_REGION
